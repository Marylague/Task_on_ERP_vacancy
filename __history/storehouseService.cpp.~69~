void StorehouseService::receiveProduct() {
    int id, quantity;

    std::cout << "Product ID: ";
    std::cin >> id;

    std::cout << "Quantity: ";
    std::cin >> quantity;

    if (quantity <= 0) {
        std::cout << "Quantity must be > 0\n";
        return;
    }

    std::string query =
        "SELECT quantity, storehouse_id FROM products WHERE id = " +
        std::to_string(id) + ";";

    sqlite3_stmt* stmt = db.query(query);

    if (sqlite3_step(stmt) != SQLITE_ROW) {
        std::cout << "Product not found\n";
        sqlite3_finalize(stmt);
        return;
    }

    int currentQuantity = sqlite3_column_int(stmt, 0);
    int storehouseId = sqlite3_column_int(stmt, 1);
    int newQuantity = currentQuantity + quantity;

    sqlite3_finalize(stmt);

    db.execute(
        "UPDATE products SET quantity = " + std::to_string(newQuantity) +
        " WHERE id = " + std::to_string(id) + ";"
    );

    db.execute(
        "INSERT INTO history (product_id, operation_type, operation_quantity, previous_quantity, new_quantity, storehouse_id) "
        "VALUES (" +
        std::to_string(id) + ", 'receipt', " +
        std::to_string(quantity) + ", " +
        std::to_string(currentQuantity) + ", " +
        std::to_string(newQuantity) + ", " +
        std::to_string(storehouseId) + ");"
    );

    std::cout << "Receipt done\n";
}

void StorehouseService::shipProduct() {
    int id, quantity;

    std::cout << "Product ID: ";
    std::cin >> id;

    std::cout << "Quantity: ";
    std::cin >> quantity;

    if (quantity <= 0) {
        std::cout << "Quantity must be > 0\n";
        return;
    }

    std::string query =
        "SELECT quantity, storehouse_id FROM products WHERE id = " +
        std::to_string(id) + ";";

    sqlite3_stmt* stmt = db.query(query);

    if (sqlite3_step(stmt) != SQLITE_ROW) {
        std::cout << "Product not found\n";
        sqlite3_finalize(stmt);
        return;
    }

    int currentQuantity = sqlite3_column_int(stmt, 0);
    int storehouseId = sqlite3_column_int(stmt, 1);

    if (currentQuantity < quantity) {
        std::cout << "Not enough stock!\n";
        sqlite3_finalize(stmt);
        return;
    }

    int newQuantity = currentQuantity - quantity;

    sqlite3_finalize(stmt);

    db.execute(
        "UPDATE products SET quantity = " + std::to_string(newQuantity) +
        " WHERE id = " + std::to_string(id) + ";"
    );

    db.execute(
        "INSERT INTO history (product_id, operation_type, operation_quantity, previous_quantity, new_quantity, storehouse_id) "
        "VALUES (" +
        std::to_string(id) + ", 'shipment', " +
        std::to_string(quantity) + ", " +
        std::to_string(currentQuantity) + ", " +
        std::to_string(newQuantity) + ", " +
        std::to_string(storehouseId) + ");"
    );

    std::cout << "Shipment done\n";
}

void StorehouseService::showHistory() {
    std::string query =
        "SELECT h.id, p.name, h.operation_type, h.operation_quantity, "
        "h.previous_quantity, h.new_quantity, s.name, h.created_at "
        "FROM history h "
        "JOIN products p ON h.product_id = p.id "
        "LEFT JOIN storehouses s ON h.storehouse_id = s.id;";

    sqlite3_stmt* stmt = db.query(query);

    while (sqlite3_step(stmt) == SQLITE_ROW) {
        std::cout
            << "ID: " << sqlite3_column_int(stmt, 0)
            << " | Product: " << sqlite3_column_text(stmt, 1)
            << " | Type: " << sqlite3_column_text(stmt, 2)
            << " | Quantity: " << sqlite3_column_int(stmt, 3)
            << " | Before: " << sqlite3_column_int(stmt, 4)
            << " | After: " << sqlite3_column_int(stmt, 5)
            << " | Storehouse: "
            << (sqlite3_column_text(stmt, 6) ? (const char*)sqlite3_column_text(stmt, 6) : "NULL")
            << " | Date: " << sqlite3_column_text(stmt, 7)
            << "\n";
    }

    sqlite3_finalize(stmt);
    std::cout << "Finish showing";
}

