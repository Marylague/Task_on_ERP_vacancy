    std::string query =
        "SELECT id, name, quantity, price FROM products WHERE storehouse_id = " +
        std::to_string(storehouseId) + ";";

    sqlite3_stmt* stmt = db.query(query);

    bool found = false;

    while (sqlite3_step(stmt) == SQLITE_ROW) {
        found = true;

        std::cout
            << "ID: " << sqlite3_column_int(stmt, 0)
