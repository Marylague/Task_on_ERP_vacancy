StorehouseService::StorehouseService(Database& database) : db(database) {}

void StorehouseService::showProducts() {
    std::string query =
        "SELECT p.id, p.name, p.quantity, p.price, s.id, s.name "
        "FROM products p LEFT JOIN storehouses s ON p.storehouse_id = s.id;";

    sqlite3_stmt* stmt = db.query(query);

    bool found = false;

    while (sqlite3_step(stmt) == SQLITE_ROW) {
        found = true;

        std::cout
            << "Id: " << sqlite3_column_int(stmt, 0) << " | "
            << "Name: " << sqlite3_column_text(stmt, 1) << " | "
            << "Quantity: " << sqlite3_column_int(stmt, 2) << " | "
            << "Price: " << sqlite3_column_double(stmt, 3) << " | "
            << "Store Id: " << sqlite3_column_int(stmt, 4) << " | "
            << "Store Name: "
            << (sqlite3_column_text(stmt, 5) ? (const char*)sqlite3_column_text(stmt, 5) : "NULL")
            << "\n";
    }

    if (!found) std::cout << "No products found!\n";

    sqlite3_finalize(stmt);
}

