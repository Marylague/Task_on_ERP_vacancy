StorehouseService::StorehouseService(Database& database) : db(database) {}

void StorehouseService::showProducts() {
    PGresult* res = db.execute(
        "SELECT p.id, p.name, p.quantity, p.price, s.id, s.name "
        "FROM products p LEFT JOIN storehouses s ON p.storehouse_id = s.id;"
    );

    int rows = PQntuples(res);

    if (rows == 0) {
        std::cout << "No products found!\n";
        PQclear(res);
        return;
    }

    for (int i = 0; i < rows; i++) {
        std::cout
            << "Id: " << PQgetvalue(res, i, 0) << " | "
            << "Name: " << PQgetvalue(res, i, 1) << " | "
            << "Quantity: " << PQgetvalue(res, i, 2) << " | "
            << "Price: " << PQgetvalue(res, i, 3) << " | "
            << "Store Id: " << PQgetvalue(res, i, 4) << " | "
            << "Store Name: " << PQgetvalue(res, i, 5) << "\n";
    }

    PQclear(res);
    std::cout << "Finish showing";
}

