void StorehouseService::receiveProduct() {
    int id, quantity;

    std::cout << "Product ID: ";
    std::cin >> id;

    std::cout << "Quantity: ";
    std::cin >> quantity;

    if (quantity < 0) {
    	std::cout << "Quantity cannot be negative\n";
    	return;
	}

    PGresult* res = db.execute(
        "SELECT quantity, storehouse_id FROM products WHERE id = " +
        std::to_string(id) + ";"
    );

    if (PQntuples(res) == 0) {
        std::cout << "Product not found\n";
        PQclear(res);
        return;
    }

    int currentQuantity = atoi(PQgetvalue(res, 0, 0));
    int storehouseId = atoi(PQgetvalue(res, 0, 1));
    int newQuantity = currentQuantity + quantity;

    db.execute(
        "UPDATE products SET quantity = " + std::to_string(newQuantity) +
        " WHERE id = " + std::to_string(id) + ";"
    );

    db.execute(
        "INSERT INTO history "
        "(product_id, operation_type, operation_quantity, previous_quantity, new_quantity, storehouse_id) "
        "VALUES (" +
        std::to_string(id) + ", 'receipt', " +
        std::to_string(quantity) + ", " +
        std::to_string(currentQuantity) + ", " +
        std::to_string(newQuantity) + ", " +
        std::to_string(storehouseId) + ");"
    );

    PQclear(res);

    std::cout << "Receipt done\n";
}

void StorehouseService::shipProduct() {
    int id, quantity;

    std::cout << "Product ID: ";
    std::cin >> id;

    std::cout << "Quantity: ";
    std::cin >> quantity;

    PGresult* res = db.execute(
        "SELECT quantity, storehouse_id FROM products WHERE id = " +
        std::to_string(id) + ";"
    );

    if (PQntuples(res) == 0) {
        std::cout << "Product not found!\n";
        PQclear(res);
        return;
    }

    int currentQuantity = atoi(PQgetvalue(res, 0, 0));
    int storehouseId = atoi(PQgetvalue(res, 0, 1));

    if (currentQuantity < quantity) {
        std::cout << "Not enough stock!\n";
        PQclear(res);
        return;
    }

    int newQuantity = currentQuantity - quantity;

    db.execute(
        "UPDATE products SET quantity = " + std::to_string(newQuantity) +
        " WHERE id = " + std::to_string(id) + ";"
    );

    db.execute(
        "INSERT INTO history "
        "(product_id, operation_type, operation_quantity, previous_quantity, new_quantity, storehouse_id) "
        "VALUES (" +
        std::to_string(id) + ", 'shipment', " +
        std::to_string(quantity) + ", " +
        std::to_string(currentQuantity) + ", " +
        std::to_string(newQuantity) + ", " +
        std::to_string(storehouseId) + ");"
    );

    PQclear(res);

    std::cout << "Shipment done\n";
}


void StorehouseService::showHistory() {
    std::string query =
        "SELECT h.id, p.name, h.operation_type, h.operation_quantity, "
        "h.previous_quantity, h.new_quantity, s.name, h.created_at "
        "FROM history h "
        "JOIN products p ON h.product_id = p.id "
        "LEFT JOIN storehouses s ON h.storehouse_id = s.id;";

    PGresult* res = db.execute(query);

    for (int i = 0; i < PQntuples(res); i++) {
        std::cout
            << "ID: " << PQgetvalue(res, i, 0)
            << " | Product: " << PQgetvalue(res, i, 1)
            << " | Type: " << PQgetvalue(res, i, 2)
            << " | Quantity: " << PQgetvalue(res, i, 3)
            << " | Before: " << PQgetvalue(res, i, 4)
            << " | After: " << PQgetvalue(res, i, 5)
            << " | Storehouse: " << PQgetvalue(res, i, 6)
            << " | Date: " << PQgetvalue(res, i, 7)
            << "\n";
    }

    PQclear(res);
}

